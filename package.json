{
  "name": "0ctx",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core/tsconfig.json packages/daemon/tsconfig.json packages/mcp/tsconfig.json && node packages/cli/build.mjs",
    "typecheck": "tsc -b packages/core/tsconfig.json packages/daemon/tsconfig.json packages/mcp/tsconfig.json packages/cli/tsconfig.json --pretty false",
    "dev": "npm run dev --workspace=packages/daemon",
    "dev:cli": "npm run dev --workspace=@0ctx/cli",
    "dev:ui": "npm run db:migrate --prefix ui && npm run dev --prefix ui",
    "start:ui": "npm run start --prefix ui",
    "start:mcp": "node packages/mcp/dist/index.js",
    "dev:mcp": "node packages/mcp/dist/index.js",
    "cli": "node packages/cli/dist/index.js",
    "cli:install-local": "npm run build && node -e \"const{execSync}=require('child_process');const fs=require('fs');const g=execSync('npm root -g').toString().trim();const dir=g+'/@0ctx/cli/dist';fs.mkdirSync(dir,{recursive:true});['index.js','mcp-server.js','daemon.js'].forEach(f=>fs.copyFileSync('packages/cli/dist/'+f,dir+'/'+f));console.log('Installed to '+dir);\"",
    "bootstrap:mcp": "npm run build && node packages/mcp/dist/bootstrap.js",
    "bootstrap:mcp:dry": "npm run build && node packages/mcp/dist/bootstrap.js --dry-run",
    "desktop:smoke": "npm run smoke --prefix desktop-app",
    "desktop:electron:dev": "npm run dev --prefix desktop-app",
    "desktop:electron:build": "npm run build --prefix desktop-app",
    "desktop:electron:test": "npm run test --prefix desktop-app",
    "desktop:electron:smoke": "npm run smoke --prefix desktop-app",
    "repo:check-nested-git": "powershell -ExecutionPolicy Bypass -File scripts/repo/check-nested-git.ps1",
    "repo:adopt-ui:dry": "powershell -ExecutionPolicy Bypass -File scripts/repo/adopt-ui-monorepo.ps1",
    "repo:adopt-ui": "powershell -ExecutionPolicy Bypass -File scripts/repo/adopt-ui-monorepo.ps1 -Apply",
    "repo:github:bootstrap:dry": "powershell -ExecutionPolicy Bypass -File scripts/repo/bootstrap-github.ps1 -DryRun",
    "release:validate": "powershell -ExecutionPolicy Bypass -File scripts/release/validate-release.ps1",
    "release:e2e:ga": "node scripts/release/verify-ga-agents.mjs",
    "release:e2e:daily": "node scripts/release/verify-daily-flow.mjs",
    "release:e2e:desktop:real": "node scripts/release/verify-desktop-real-flow.mjs",
    "release:report": "node scripts/release/generate-release-report.mjs",
    "release:desktop:artifacts": "node scripts/release/package-desktop-artifacts.mjs",
    "release:changelog:prepare": "powershell -ExecutionPolicy Bypass -File scripts/release/prepare-changelog.ps1",
    "release:tag:dry": "powershell -ExecutionPolicy Bypass -File scripts/release/tag-preview.ps1",
    "release:pack:dry": "npm pack --workspace=@0ctx/cli --dry-run",
    "release:cli": "npm run build && node packages/cli/dist/index.js release publish",
    "release:cli:dry": "npm run build && node packages/cli/dist/index.js release publish --dry-run",
    "release:publish:dry": "powershell -ExecutionPolicy Bypass -File scripts/release/publish-packages.ps1 -DryRun",
    "release:publish": "powershell -ExecutionPolicy Bypass -File scripts/release/publish-packages.ps1",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
