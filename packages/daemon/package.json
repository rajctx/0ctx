{
  "name": "@0ctx/daemon",
  "version": "0.1.0",
  "private": true,
  "description": "0ctx persistent local daemon – IPC server and DB owner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "context",
    "daemon",
    "ipc",
    "local-first"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@0ctx/core": "^1.0.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}