{
  "name": "@0ctx/mcp",
  "version": "0.1.9",
  "private": true,
  "description": "0ctx MCP stdio server – translates tool calls into daemon IPC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "bootstrap": "node dist/bootstrap.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "context",
    "mcp",
    "model-context-protocol",
    "local-first"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@0ctx/core": "*",
    "@0ctx/daemon": "*",
    "@modelcontextprotocol/sdk": "^1.5.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}