// CLOUD-002: Prisma v7 schema for control-plane persistence
// Models match the existing 001_control_plane.sql migration

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Tenants ──────────────────────────────────────────────────────────────────

model Tenant {
  tenantId   String   @id @map("tenant_id")
  name       String   @default("")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  settings   Json     @default("{}")

  connectors Connector[]
  commands   Command[]

  @@map("tenants")
}

// ── Connectors ───────────────────────────────────────────────────────────────

model Connector {
  machineId       String    @map("machine_id")
  tenantId        String    @map("tenant_id")           // non-nullable — every connector must belong to a tenant
  registrationId  String    @map("registration_id")
  streamUrl       String    @default("") @map("stream_url")
  capabilities    Json      @default("[\"sync\",\"blackboard\",\"commands\"]")
  posture         String?
  trustLevel      String    @default("unverified") @map("trust_level")
  trustVerifiedAt DateTime? @map("trust_verified_at") @db.Timestamptz
  registeredAt    DateTime  @default(now()) @map("registered_at") @db.Timestamptz
  lastHeartbeatAt DateTime? @map("last_heartbeat_at") @db.Timestamptz

  tenant          Tenant           @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  commands        Command[]
  eventsIngest    EventsIngest[]
  trustChallenge  TrustChallenge?

  @@id([tenantId, machineId])   // composite PK — two tenants can have the same machineId
  @@map("connectors")
}

// ── Commands ─────────────────────────────────────────────────────────────────

model Command {
  commandId  String   @id @map("command_id")
  machineId  String   @map("machine_id")
  cursor     BigInt   @default(autoincrement())
  tenantId   String   @map("tenant_id")              // non-nullable — matches connector tenantId
  contextId  String?  @map("context_id")
  method     String
  params     Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  status     String   @default("pending")
  result     Json?
  error      String?

  connector  Connector @relation(fields: [tenantId, machineId], references: [tenantId, machineId], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [tenantId])

  @@index([machineId, status, cursor], map: "idx_commands_machine_status")
  @@index([tenantId], map: "idx_commands_tenant")
  @@map("commands")
}

// ── Events ingest ────────────────────────────────────────────────────────────

model EventsIngest {
  id             String   @id
  machineId      String   @map("machine_id")
  tenantId       String   @map("tenant_id")            // non-nullable — matches connector tenantId
  subscriptionId String   @default("") @map("subscription_id")
  cursor         BigInt   @default(0)
  events         Json     @default("[]")
  receivedAt     DateTime @default(now()) @map("received_at") @db.Timestamptz

  connector      Connector @relation(fields: [tenantId, machineId], references: [tenantId, machineId], onDelete: Cascade)

  @@index([machineId], map: "idx_events_machine")
  @@index([tenantId], map: "idx_events_tenant")
  @@index([receivedAt(sort: Desc)], map: "idx_events_received")
  @@map("events_ingest")
}

// ── Trust challenges ─────────────────────────────────────────────────────────

model TrustChallenge {
  machineId  String   @map("machine_id")
  tenantId   String   @map("tenant_id")              // part of composite PK + FK
  nonce      String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  expiresAt  DateTime @map("expires_at") @db.Timestamptz

  connector  Connector @relation(fields: [tenantId, machineId], references: [tenantId, machineId], onDelete: Cascade)

  @@id([tenantId, machineId])
  @@map("trust_challenges")
}
