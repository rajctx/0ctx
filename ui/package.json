    "start": "node scripts/run-next.js start",
    "typecheck": "node scripts/reset-next-types.js && node scripts/run-next.js typegen && tsc --project tsconfig.typecheck.json --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.40.0",
    "@types/d3-force": "^3.0.10",
