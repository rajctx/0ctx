# Optional 0ctx contributor overrides
# Copy to .env only if you need local overrides while developing this repo.
#
# The normal open-source path does not require a repo-level .env file.
# `@0ctx/cli` works with local defaults under ~/.0ctx/.

# ── Local Runtime Overrides ──────────────────────────────────────────────────
# CTX_DB_PATH=
# CTX_SOCKET_PATH=
# CTX_CONFIG_PATH=

# ── Telemetry (disabled by default) ──────────────────────────────────────────
# A clean source build does not send telemetry unless you explicitly enable it
# and configure a PostHog project key.
# CTX_TELEMETRY_ENABLED=true
# CTX_POSTHOG_API_KEY=
# CTX_POSTHOG_HOST=https://us.i.posthog.com

# ── UI / dev-only surfaces ───────────────────────────────────────────────────
# UI-specific env vars belong in ui/.env.example instead of the repo root.
